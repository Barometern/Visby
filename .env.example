# Frontend: admin UI hidden unless explicitly enabled in production.
VITE_ENABLE_ADMIN=false
VITE_GOOGLE_MAPS_API_KEY=

# Backend: admin API disabled unless explicitly enabled in production.
ENABLE_ADMIN=false
DATABASE_URL=
PGSSL_MODE=disable
PGSSL_INSECURE_SKIP_VERIFY=false

# Optional one-time admin bootstrap in environments where you control the server.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
