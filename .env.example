# ---------------------------------------------------------------------------
# Visby Quest local environment template
# Copy this file to `.env` and replace the example values below.
# ---------------------------------------------------------------------------

# Frontend
# The admin UI is already visible in local Vite dev because `import.meta.env.DEV`
# is true, but you can keep this here for parity with production.
VITE_ENABLE_ADMIN=false
VITE_GOOGLE_MAPS_API_KEY=

# Backend server
NODE_ENV=development
PORT=8787

# Postgres
# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visbyquest
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/YOUR_DATABASE

# SSL settings for Postgres.
# For a normal local Postgres install, keep `disable`.
# For hosted databases, use `require` if needed by your provider.
PGSSL_MODE=disable
PGSSL_INSECURE_SKIP_VERIFY=false

# Admin behavior
# In development the backend admin API is enabled even if this is false,
# because the server only disables admin automatically in production.
ENABLE_ADMIN=false

# Optional one-time admin bootstrap user created/updated on server start.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-sharing
